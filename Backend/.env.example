PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/padelme?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/padelme?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="30d"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-pass"
SMTP_FROM="PadelMe <no-reply@padelme.app>"
OTP_EXPIRES_MINUTES=10

# Google Sign-In: comma-separated OAuth 2.0 client IDs (Web + iOS + Android) used to verify ID tokens from the app
# GOOGLE_OAUTH_CLIENT_IDS="123-abc.apps.googleusercontent.com,456-def.apps.googleusercontent.com"
# Or a single web client:
# GOOGLE_WEB_CLIENT_ID="123-abc.apps.googleusercontent.com"
#
# Cloud Run: git push does not deploy. From Backend/: ./scripts/deploy-cloud-run.sh
# (merges GOOGLE_OAUTH_CLIENT_IDS with app IDs; set DATABASE_URL/JWT_SECRET in Console or gcloud.)
#
# Sign in with Apple (native iOS): must match Xcode bundle ID (JWT audience).
# APPLE_CLIENT_ID="com.mipadel"
# Aliases: APPLE_BUNDLE_ID, IOS_BUNDLE_ID

# Auto-cancel stale scheduled matches (past slot, still open/full). In-process cron runs twice daily UTC.
# OPTIONAL: GCP Cloud Scheduler can POST JSON to /api/internal/cleanup-stale-matches with:
#   Authorization: Bearer <STALE_MATCH_CRON_SECRET>   (or header x-cron-secret)
# DISABLE_STALE_MATCH_CRON=1   # skip in-process cron (use Scheduler only if you prefer)
# STALE_MATCH_BOOT_DELAY_MS=45000   # ms before first run after server boot
# STALE_MATCH_CRON_SECRET="long-random-string"
