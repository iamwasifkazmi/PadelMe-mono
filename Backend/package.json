{
  "name": "padelme-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"tsx src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
